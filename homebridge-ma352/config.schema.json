{
  "pluginAlias": "MA352Platform",
  "pluginType": "platform",
  "name": "MA352 Platform",
  "schema": {
    "type": "object",
    "properties": {
      "host": {
        "title": "Bridge Host",
        "type": "string",
        "default": "127.0.0.1",
        "description": "IP address or hostname of the MA352 bridge service"
      },
      "port": {
        "title": "Bridge Port",
        "type": "number",
        "default": 5000,
        "description": "HTTP port for the MA352 bridge service"
      },
      "name": {
        "title": "Accessory Name",
        "type": "string",
        "default": "McIntosh Amp",
        "description": "Name of the single accessory shown in Home app"
      },
      "inputs": {
        "title": "Inputs",
        "type": "array",
        "description": "Optional list of inputs to expose. If omitted, defaults are used.",
        "items": {
          "type": "object",
          "properties": {
            "value": {
              "title": "Input Value",
              "type": "number",
              "minimum": 1,
              "maximum": 9
            },
            "name": {
              "title": "Input Name",
              "type": "string"
            }
          },
          "required": ["value", "name"]
        }
      }
    }
  }
}
